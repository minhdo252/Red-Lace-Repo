# --- Postgres ---
POSTGRES_USER=aitravelmate
POSTGRES_PASSWORD=aitravelmate
POSTGRES_DB=aitravelmate

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- AI client ---
# Leave AI_MODE=mock to run the whole stack with canned responses (no key needed).
# AI_MODE=live wires an OpenAI-compatible endpoint (FPT Cloud Marketplace by
# default). Each capability can use a different model + key on that endpoint.
AI_MODE=mock
AI_BASE_URL=https://mkp-api.fptcloud.com

AI_CHAT_API_KEY=
AI_CHAT_MODEL=GLM-5.2

AI_VISION_API_KEY=
AI_VISION_MODEL=Qwen2.5-VL-7B-Instruct

AI_EMBED_API_KEY=
AI_EMBED_MODEL=Vietnamese_Embedding

# --- Embedding dimension used for Qdrant collections ---
# Must match the embedding model wired into ai/client.py::embed() —
# Vietnamese_Embedding above outputs 1024-dim vectors.
EMBEDDING_DIM=1024

# --- Optional external APIs (module 2.2 signals) ---
GOOGLE_PLACES_API_KEY=
