# --- Postgres ---
POSTGRES_USER=aitravelmate
POSTGRES_PASSWORD=aitravelmate
POSTGRES_DB=aitravelmate

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- AI client ---
# Leave AI_MODE=mock to run the whole stack with canned responses (no key needed).
# Switch to AI_MODE=live to call AI Marketplace through backend/app/ai/client.py.
AI_MODE=mock
AI_MARKETPLACE_BASE_URL=https://mkp-api.fptcloud.com
AI_API_KEY=
AI_MODEL=Llama-3.3-70B-Instruct
STT_MODEL=FPT.AI-whisper-large-v3-turbo
EMBEDDING_MODEL=Vietnamese_Embedding
VISION_MODEL=Qwen2.5-VL-7B-Instruct
AI_REQUEST_TIMEOUT_SECONDS=60

# --- Embedding dimension used for Qdrant collections ---
# Vietnamese_Embedding on AI Marketplace is expected to be 1024 dimensions.
EMBEDDING_DIM=1024

# --- Optional external APIs (module 2.2 signals) ---
GOOGLE_PLACES_API_KEY=

# --- Qwen2.5-VL menu detection (backend/app/ai/qwen_vl.py) ---
QWEN_VL_API_KEY=

# --- Whisper V3 (backend/app/ai/whisper_v3.py) ---
WHISPER_V3_API_KEY=

# --- vn-embedding-base (backend/app/ai/embedding.py) ---
VN_EMBEDDING_API_KEY=

# --- GLM API (backend/app/ai/glm_chat.py) ---
GLM_API_KEY=


