# --- Postgres ---
POSTGRES_USER=aitravelmate
POSTGRES_PASSWORD=aitravelmate
POSTGRES_DB=aitravelmate

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- AI client (placeholder) ---
# Leave AI_MODE=mock to run the whole stack with canned responses (no key needed).
# Switch to AI_MODE=live and wire your own API call in backend/app/ai/client.py
# once you're ready to plug in your existing LLM integration.
AI_MODE=mock
AI_API_KEY=
AI_MODEL=

# --- Embedding dimension used for Qdrant collections ---
# Must match whatever embedding model you end up wiring into ai/client.py::embed()
EMBEDDING_DIM=384

# --- Optional external APIs (module 2.2 signals) ---
GOOGLE_PLACES_API_KEY=
