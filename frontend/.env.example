# Frontend environment variables. Copy to `.env.local` and fill in.
# (.env.local is gitignored; this .example is the committed template.)

# --- FastAPI backend (server-side only; never exposed to the browser) ---
# Base URL of the deployed backend, e.g. https://aitravelmate-backend.up.railway.app
# Leave EMPTY to run the whole app on mock data (every AI feature still works,
# just with the built-in canned responses instead of the live backend).
BACKEND_URL=

# --- Map screen (existing) ---
# SerpApi Google Maps key for /api/nearby (server-side only). Optional: the map
# falls back to curated mock places without it.
SERPAPI_KEY=

# --- Optional interactive Google Map (client-side, inlined at build) ---
# A real Maps JavaScript API key (AIza...) with billing enabled. When set, the map
# switches to the interactive Google Maps version; otherwise it uses the free
# iframe + SerpApi list. Must be set BEFORE build.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
